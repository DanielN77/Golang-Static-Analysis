              "helpUri": "https://pkg.go.dev/vuln/GO-2025-4134",
              "properties": {
                "tags": [
                  "CVE-2025-58181",
                  "GHSA-j5w8-q4qc-rx2x"
                ]
              }
            },
            {
              "id": "GO-2025-4135",
              "shortDescription": {
                "text": "[GO-2025-4135] Malformed constraint may cause denial of service in golang.org/x/crypto/ssh/agent"
              },
              "fullDescription": {
                "text": "Malformed constraint may cause denial of service in golang.org/x/crypto/ssh/agent"
              },
              "help": {
                "text": "SSH Agent servers do not validate the size of messages when processing new identity requests, which may cause the program to panic if the message is malformed due to an out of bounds read."
              },
              "helpUri": "https://pkg.go.dev/vuln/GO-2025-4135",
