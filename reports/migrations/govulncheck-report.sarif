                ]
              }
            },
            {
              "id": "GO-2025-4134",
              "shortDescription": {
                "text": "[GO-2025-4134] Unbounded memory consumption in golang.org/x/crypto/ssh"
              },
              "fullDescription": {
                "text": "Unbounded memory consumption in golang.org/x/crypto/ssh"
              },
              "help": {
                "text": "SSH servers parsing GSSAPI authentication requests do not validate the number of mechanisms specified in the request, allowing an attacker to cause unbounded memory consumption."
