            {
              "id": "GO-2025-4116",
              "shortDescription": {
                "text": "[GO-2025-4116] Potential denial of service in golang.org/x/crypto/ssh/agent"
              },
              "fullDescription": {
                "text": "Potential denial of service in golang.org/x/crypto/ssh/agent"
              },
              "help": {
                "text": "SSH clients receiving SSH_AGENT_SUCCESS when expecting a typed response will panic and cause early termination of the client process."
              },
              "helpUri": "https://pkg.go.dev/vuln/GO-2025-4116",
              "properties": {
